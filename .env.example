# Copy to .env and fill in. Never commit .env.

# ─── Django ────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api,frontend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://yakimaweb:yakimaweb@db:5432/yakimaweb

# ─── Redis (cache + sessions + Celery broker + rate limiting) ──────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── CORS (Next.js frontend → Django API) ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── Admin lockdown ────────────────────────────────────────────────────
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
DJANGO_OTP_REQUIRED_FOR_STAFF=True

# ─── AI — Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODERATION_MODEL=gemini-2.5-flash
GEMINI_TOOLS_MODEL=gemini-2.5-pro
GEMINI_DAILY_SPEND_CAP_USD=50.00

# ─── License Verification — ARELLO ─────────────────────────────────────
ARELLO_BASE_URL=https://lvws-sandbox.arello.com
ARELLO_API_KEY=
ARELLO_VERIFICATION_INTERVAL_DAYS=30

# ─── Email (Postmark via Anymail) ──────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=hello@yakimaweb.com
SERVER_EMAIL=ops@yakimaweb.com
POSTMARK_SERVER_TOKEN=

# ─── Storage (Cloudflare R2 — S3-compatible) ───────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=yakimaweb-media
AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=media.yakimaweb.com
AWS_S3_REGION_NAME=auto

# ─── Sentry ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Feature flags ─────────────────────────────────────────────────────
FEATURE_AI_TOOLS=False
FEATURE_MARKETPLACE=True
FEATURE_FORUM=True

# ─── Caddy / domain ────────────────────────────────────────────────────
DOMAIN=localhost

# ─── Frontend (Next.js 15) ─────────────────────────────────────────────
# Browser-side fetches go through Caddy (public origin).
NEXT_PUBLIC_API_BASE_URL=http://localhost
# Server-side RSC fetches stay inside the docker network.
INTERNAL_API_BASE_URL=http://api:8000
NEXT_PUBLIC_SITE_NAME=Yakima Real Estate Hub
