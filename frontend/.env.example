# Copy to frontend/.env for local Next.js dev. Never commit frontend/.env.
# Most values are overridden by docker-compose.yml in containerized dev.

# Browser-side fetches go through Caddy (public origin).
NEXT_PUBLIC_API_BASE_URL=http://localhost

# Server-side fetches (RSC, route handlers) stay inside the docker network.
INTERNAL_API_BASE_URL=http://api:8000

NEXT_PUBLIC_SITE_NAME=Yakima Real Estate Hub
