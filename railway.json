{
  "$schema": "https://railway.app/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "Dockerfile" },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 100,
    "startCommand": "python manage.py migrate --noinput && gunicorn config.wsgi:application --bind 0.0.0.0:$PORT --workers 3 --access-logfile -"
  },
  "services": [
    {
      "name": "web",
      "source": { "type": "image", "image": "ghcr.io/yakimaweb/web:latest" }
    },
    {
      "name": "celery-worker",
      "source": { "type": "image", "image": "ghcr.io/yakimaweb/web:latest" },
      "deploy": {
        "startCommand": "celery -A config worker --loglevel=info --concurrency=2"
      }
    },
    {
      "name": "celery-beat",
      "source": { "type": "image", "image": "ghcr.io/yakimaweb/web:latest" },
      "deploy": {
        "startCommand": "celery -A config beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler"
      }
    }
  ]
}
